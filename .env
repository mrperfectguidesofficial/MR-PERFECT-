# Public API Keys
EXCHANGE_RATE=EXCHANGE_RATE_PUBLIC_API_KEY
IPAPI=IPAPI_PUBLIC_API_KEY
RESTCOUNTRIES_API=RESTCOUNTRIES_PUBLIC_API_KEY

# OpenRouter
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=openrouter/free

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Firebase Web Config (Used securely in Backend)
FIREBASE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxx
FIREBASE_AUTH_DOMAIN=project.firebaseapp.com
FIREBASE_PROJECT_ID=project-id
FIREBASE_STORAGE_BUCKET=project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_APP_ID=1:1234567890:web:abcdef
FIREBASE_MEASUREMENTID=measurementId

# reCAPTCHA
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

ALLOWED_ORIGIN=*
